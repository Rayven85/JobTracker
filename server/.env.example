# PostgreSQL
DATABASE_URL=postgresql://jobtracker:password@localhost:5432/jobtracker
DATABASE_TEST_URL=postgresql://jobtracker:password@localhost:5432/jobtracker_test

# JWT — generate each with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# URLs
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:4000
PORT=4000
NODE_ENV=development

# Groq (free tier — https://console.groq.com)
GROQ_API_KEY=

# AWS S3 (IAM user needs PutObject / GetObject / DeleteObject on the bucket)
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=jobtracker-resumes-dev

# Google OAuth — required at startup (passport config checks for non-empty values).
# If you don't need Google login locally, set any placeholder, e.g. "dev-placeholder".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
